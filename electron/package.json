{
  "name": "billiardbar-pos-desktop",
  "version": "1.0.0",
  "description": "BilliardBar POS Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^25.9.8",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.billiardbar.pos",
    "productName": "BilliardBar POS",
    "copyright": "Copyright © 2025 BilliardBar",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "setup.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/billiardbar-backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "BilliardBarPOS-Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BilliardBar POS",
      "menuCategory": "BilliardBar",
      "deleteAppDataOnUninstall": false
    },
    "asar": false
  }
}
