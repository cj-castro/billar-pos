<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <UI>

      <!-- ════════════════════════════════════════════════════════════
           Database Configuration Dialog
           ════════════════════════════════════════════════════════════ -->
      <Dialog Id="DbConfigDlg" Width="370" Height="300" Title="[ProductName] — Database Configuration">

        <!-- Banner -->
        <Control Id="BannerBitmap" Type="Bitmap"   X="0"   Y="0"   Width="370" Height="44" TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine"   Type="Line"      X="0"   Y="44"  Width="370" Height="0" />
        <Control Id="BottomLine"   Type="Line"      X="0"   Y="234" Width="370" Height="0" />

        <!-- Heading -->
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes">
          <Text Value="{\WixUI_Font_Title}Database Configuration" />
        </Control>
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="18" Transparent="yes" NoPrefix="yes">
          <Text Value="Enter your PostgreSQL connection details." />
        </Control>

        <!-- Host -->
        <Control Id="DbHostLabel" Type="Text" X="20"  Y="60"  Width="100" Height="12" TabSkip="yes">
          <Text Value="Database &amp;Host:" />
        </Control>
        <Control Id="DbHostEdit"  Type="Edit" X="130" Y="57"  Width="160" Height="17" Property="DB_HOST"     Text="{100}" />

        <!-- Port -->
        <Control Id="DbPortLabel" Type="Text" X="20"  Y="84"  Width="100" Height="12" TabSkip="yes">
          <Text Value="Database &amp;Port:" />
        </Control>
        <Control Id="DbPortEdit"  Type="Edit" X="130" Y="81"  Width="80"  Height="17" Property="DB_PORT"     Text="{5}" />

        <!-- Database Name -->
        <Control Id="DbNameLabel" Type="Text" X="20"  Y="108" Width="100" Height="12" TabSkip="yes">
          <Text Value="Database &amp;Name:" />
        </Control>
        <Control Id="DbNameEdit"  Type="Edit" X="130" Y="105" Width="160" Height="17" Property="DB_NAME"     Text="{64}" />

        <!-- Username -->
        <Control Id="DbUserLabel" Type="Text" X="20"  Y="132" Width="100" Height="12" TabSkip="yes">
          <Text Value="Database &amp;Username:" />
        </Control>
        <Control Id="DbUserEdit"  Type="Edit" X="130" Y="129" Width="160" Height="17" Property="DB_USER"     Text="{64}" />

        <!-- Password -->
        <Control Id="DbPassLabel" Type="Text" X="20"  Y="156" Width="100" Height="12" TabSkip="yes">
          <Text Value="Database &amp;Password:" />
        </Control>
        <Control Id="DbPassEdit"  Type="Edit" X="130" Y="153" Width="160" Height="17" Property="DB_PASSWORD" Password="yes" Text="{128}" />

        <Control Id="DbPassNote" Type="Text" X="20" Y="178" Width="320" Height="20" Transparent="yes" NoPrefix="yes">
          <Text Value="The .env file will be written to %APPDATA%\BilliardBarPOS\" />
        </Control>

        <!-- Buttons -->
        <Control Id="Back"   Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="&amp;Back">
          <Publish Event="NewDialog" Value="WelcomeDlg" Condition="1" />
        </Control>

        <Control Id="Next"   Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Next">
          <!-- Only navigate when all required fields are filled -->
          <Publish Event="NewDialog" Value="VerifyReadyDlg"
                   Condition="DB_HOST &lt;&gt; &quot;&quot; AND DB_PORT &lt;&gt; &quot;&quot; AND DB_NAME &lt;&gt; &quot;&quot; AND DB_USER &lt;&gt; &quot;&quot; AND DB_PASSWORD &lt;&gt; &quot;&quot;" />
          <!-- Show error message when password is empty -->
          <Publish Event="SpawnDialog" Value="InvalidDirDlg"
                   Condition="DB_PASSWORD = &quot;&quot;" />
        </Control>

        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>

      </Dialog>

    </UI>
  </Fragment>
</Wix>
